{
  "name": "geowiz-web",
  "version": "1.0.0",
  "scripts": {
    "branch-clean-up": "git branch -lvv | cut -c3- | awk '/: gone]/ {print $1}' | xargs git branch -D",
    "build": "ng build --configuration production --base-href /portfolio/geowiz/",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "review": "npm run lint && npm run test:headless",
    "start": "ng serve",
    "test": "ng test",
    "test:headless": "ng test --watch=false --browsers=ChromeHeadless"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.3",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.3",
    "@angular/core": "^21.0.3",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "^6.0.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.0.3",
    "jasmine-core": "^6.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
